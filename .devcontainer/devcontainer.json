{
  "name": "quickaibuy-engine",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-24-bookworm",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "forwardPorts": [
    3000
  ],
  "portsAttributes": {
    "3000": {
      "label": "Next.js",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "corepack enable && pnpm install --frozen-lockfile",
  "postAttachCommand": "pnpm db:status && NODE_ENV=production pnpm codespace:check"
}
