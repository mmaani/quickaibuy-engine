{
  "name": "quickaibuy-engine",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "openai.chatgpt"
      ]
    }
  },
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Next.js",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "corepack enable && pnpm install --no-frozen-lockfile && npm install -g @openai/codex",
  "postAttachCommand": "bash scripts/codespace_post_attach.sh"
}
