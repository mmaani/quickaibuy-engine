NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development
NODE_ENV=development
WEBSITE_URL=https://quickaibuy.com

# Required
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

# Optional
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require

# BullMQ env-specific isolation on shared Redis
BULL_PREFIX=qaib-dev
JOBS_QUEUE_NAME=jobs-dev
ENGINE_QUEUE_NAME=engine-dev

LISTING_DAILY_CAP=20
LISTING_PREPARE_LIMIT_PER_RUN=25
LISTING_PROMOTE_LIMIT_PER_RUN=25
LISTING_RATE_LIMIT_15M=3
LISTING_RATE_LIMIT_1H=8
LISTING_RATE_LIMIT_1D=15
AUTO_PURCHASE_LIMIT_PER_RUN=20
AUTO_PURCHASE_RATE_LIMIT_1H=20
AUTO_PURCHASE_RATE_LIMIT_1D=60
ALERT_PUBLISH_FAILURE_RATE_WARN_PCT=20
ALERT_PUBLISH_FAILURE_MIN_VOLUME=5
ALERT_STOCK_BLOCK_RATE_WARN_PCT=30
ALERT_STOCK_BLOCK_MIN_VOLUME=5
ALERT_PROFIT_BLOCK_RATE_WARN_PCT=35
ALERT_PROFIT_BLOCK_MIN_VOLUME=8
ALERT_SUPPLIER_FETCH_FAILURE_SPIKE_24H=15
ALERT_LISTING_PAUSE_SPIKE_24H=10
ALERT_SUPPLIER_FALLBACK_BLOCK_RATE_WARN=0.40
AUTO_APPROVE_CONFIDENCE_MIN=0.92
MATCH_MIN_CONFIDENCE=0.70
PROFIT_MIN_MATCH_CONFIDENCE=0.70
MIN_ROI_PCT=15
PROFIT_MIN_MARGIN_PCT=20
MARKETPLACE_FEE_PCT=12
OTHER_COST_USD=2
MARKETPLACE_MIN_PRICE_RATIO=1.2
MARKETPLACE_MAX_PRICE_RATIO=10
MARKETPLACE_MIN_MATCH_SCORE=0.42
MARKETPLACE_QUERY_LIMIT=5
MARKETPLACE_SCAN_DELAY_MS=100
MARKETPLACE_ALLOW_TOP_RESULT_FALLBACK=true
MATCH_MIN_MARKETPLACE_SCORE=0.42
MATCH_MIN_OVERLAP=2

# Runtime safety and diagnostics
ENABLE_EBAY_LIVE_PUBLISH=false
ENABLE_EBAY_TRACKING_SYNC=false
ENABLE_SCHEDULED_AUTONOMOUS_PUBLISH=false
ENABLE_RUNTIME_QUEUE_HEALTH_PROBE=false
ALLOW_MUTATION_SCRIPTS=false
ALLOW_PROD_DB_MUTATION=false
CONFIRM_PROD_DB_TARGET=
PGSSLMODE=require
PG_CONNECT_TIMEOUT_MS=5000
PG_RETRY_ATTEMPTS=4
PG_RETRY_BASE_DELAY_MS=750
CODESPACE_LOCAL_APP_URL=http://127.0.0.1:3000
CODESPACE_CONTROL_PAGE_TIMEOUT_MS=20000

# eBay live publish (guarded)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REFRESH_TOKEN=
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_MERCHANT_LOCATION_KEY=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=
EBAY_FULFILLMENT_POLICY_ID=
EBAY_DEFAULT_CATEGORY_ID=
EBAY_SELLER_FEEDBACK_SCORE=0
EBAY_IMAGE_PROVIDER_DEFAULT=media_api
EBAY_IMAGE_PROVIDER_ALLOW_TRADING_FALLBACK=false
MEDIA_STORAGE_MODE=reference_only

# AI listing engine (server-side only)
ENABLE_AI_LISTING_ENGINE=false
OPENAI_API_KEY=
OPENAI_LISTING_MODEL=gpt-4.1-mini
OPENAI_LISTING_VERIFY_MODEL=gpt-4.1-mini

# Worker and contact optional overrides
ORDER_SYNC_FETCH_LIMIT=25
ORDER_SYNC_LOOKBACK_HOURS=48
TRACKING_SYNC_LIMIT=20
INVENTORY_RISK_SCAN_LIMIT=200
SUPPLIER_DISCOVER_CANDIDATE_LIMIT=20
ZENROWS_API_KEY=
SCRAPINGBEE_API_KEY=
CJ_API_KEY=
NEXT_PUBLIC_CONTACT_WHATSAPP_NUMBER=962791752686
CONTACT_NOTIFICATION_EMAIL_TO=
LEAD_NOTIFICATION_EMAIL_TO=quickaibuy@gmail.com
LEAD_NOTIFICATION_EMAIL_FROM=QuickAIBuy <leads@mail.quickaibuy.com>
LEAD_EMAIL_WEBHOOK_URL=
LEAD_WHATSAPP_WEBHOOK_URL=
LEAD_NOTIFICATION_WEBHOOK_TOKEN=
LEAD_NOTIFICATION_WHATSAPP_TO=962791752686
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=
RESEND_API_KEY=
RESEND_FROM_EMAIL=QuickAIBuy <leads@mail.quickaibuy.com>
EMAIL_FROM=QuickAIBuy <leads@mail.quickaibuy.com>
NEXT_PUBLIC_VERCEL_ENV=development
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
AUTO_ORDER_PURCHASE=false
AUTO_TRACKING_SYNC=false
EBAY_USER_TOKEN=
REVIEW_CONSOLE_USERNAME=
REVIEW_CONSOLE_PASSWORD=
NX_DAEMON=false
TURBO_CACHE=remote:rw
TURBO_DOWNLOAD_LOCAL_ENABLED=true
TURBO_REMOTE_ONLY=true
TURBO_RUN_SUMMARY=true
APP_URL=http://localhost:3000
