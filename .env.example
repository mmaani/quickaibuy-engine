NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development
WEBSITE_URL=https://quickaibuy.com

# Required
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

# Optional
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require

# BullMQ env-specific isolation on shared Redis
BULL_PREFIX=qaib-dev
JOBS_QUEUE_NAME=jobs-dev
ENGINE_QUEUE_NAME=engine-dev

LISTING_DAILY_CAP=20
LISTING_PREPARE_LIMIT_PER_RUN=25
LISTING_PROMOTE_LIMIT_PER_RUN=25
LISTING_RATE_LIMIT_15M=3
LISTING_RATE_LIMIT_1H=8
LISTING_RATE_LIMIT_1D=15
AUTO_PURCHASE_LIMIT_PER_RUN=20
AUTO_PURCHASE_RATE_LIMIT_1H=20
AUTO_PURCHASE_RATE_LIMIT_1D=60
ALERT_PUBLISH_FAILURE_RATE_WARN_PCT=20
ALERT_PUBLISH_FAILURE_MIN_VOLUME=5
ALERT_STOCK_BLOCK_RATE_WARN_PCT=30
ALERT_STOCK_BLOCK_MIN_VOLUME=5
ALERT_PROFIT_BLOCK_RATE_WARN_PCT=35
ALERT_PROFIT_BLOCK_MIN_VOLUME=8
ALERT_SUPPLIER_FETCH_FAILURE_SPIKE_24H=15
ALERT_LISTING_PAUSE_SPIKE_24H=10
ALERT_SUPPLIER_FALLBACK_BLOCK_RATE_WARN=0.40
AUTO_APPROVE_CONFIDENCE_MIN=0.92
MATCH_MIN_CONFIDENCE=0.70
PROFIT_MIN_MATCH_CONFIDENCE=0.70

# eBay live publish (guarded)
ENABLE_EBAY_LIVE_PUBLISH=false
ENABLE_EBAY_TRACKING_SYNC=false
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REFRESH_TOKEN=
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_MERCHANT_LOCATION_KEY=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=
EBAY_FULFILLMENT_POLICY_ID=
EBAY_DEFAULT_CATEGORY_ID=
EBAY_SELLER_FEEDBACK_SCORE=0

# AI listing engine (server-side only)
ENABLE_AI_LISTING_ENGINE=false
OPENAI_API_KEY=
OPENAI_LISTING_MODEL=gpt-4.1-mini
