{
  "name": "quickaibuy-engine",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "env:dev": "node scripts/manage_env.mjs dev",
    "env:prod": "node scripts/manage_env.mjs prod",
    "env:status": "node scripts/manage_env.mjs status",
    "db:status": "node scripts/db_target_cli.mjs status",
    "codespace:check": "NODE_ENV=production node --import tsx scripts/check_codespace_runtime.ts",
    "scripts:check": "node --import tsx scripts/check_scripts_catalog.ts",
    "scripts:smoke": "node --import tsx scripts/check_scripts_runtime_smoke.ts",
    "db:assert-dev": "node scripts/db_target_cli.mjs assert-dev",
    "db:assert-prod": "node scripts/db_target_cli.mjs assert-prod",
    "check:mutation-safety": "node scripts/check_mutation_safety.mjs",
    "check:payment-storage": "node scripts/check_payment_storage_policy.mjs",
    "dev": "NODE_OPTIONS=--no-deprecation next dev",
    "build": "NODE_OPTIONS=--no-deprecation next build",
    "start": "NODE_OPTIONS=--no-deprecation next start",
    "lint": "eslint .",
    "test": "node --import tsx --test src/lib/**/__tests__/*.test.ts",
    "test:listings": "node --import tsx --test src/lib/listings/__tests__/*.test.ts",
    "worker:engine:dev": "pnpm env:dev && NODE_OPTIONS=--no-deprecation node --import tsx scripts/run_worker_engine_with_preflight.ts",
    "worker:engine:prod": "ALLOW_PROD_ENV_SWITCH=true pnpm env:prod && NODE_OPTIONS=--no-deprecation node --import tsx scripts/run_worker_engine_with_preflight.ts",
    "worker:jobs": "NODE_OPTIONS=--no-deprecation node --import tsx src/workers/jobs.worker.ts",
    "trend:expand:test": "node --import tsx scripts/test_trend_expand.mjs",
    "product:discover:test": "node --import tsx scripts/test_product_discover.mjs",
    "query:allocate:test": "node --import tsx scripts/test_query_budget_allocator.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "enqueue:supplier-discover": "node --import tsx scripts/enqueue_supplier_discover.ts",
    "enqueue:inventory-risk-scan": "node --import tsx scripts/enqueue_inventory_risk_scan.ts",
    "enqueue:profit-eval": "node --import tsx scripts/enqueue_profit_eval.ts",
    "probe:runtime": "node --import tsx scripts/probe_runtime.ts",
    "runtime:diag": "node --import tsx scripts/runtime_diagnostics.ts",
    "check:live-integrity": "node --import tsx scripts/check_live_state_integrity.ts",
    "ops:autonomous": "node --import tsx scripts/run_autonomous_operations.ts",
    "ops:full-cycle": "node --import tsx scripts/run_full_cycle.ts",
    "ops:learning-refresh": "node --import tsx scripts/run_learning_refresh.ts",
    "ops:supplier-wave": "node --import tsx scripts/run_supplier_wave_regeneration.ts",
    "verify:profit-pipeline": "node --import tsx scripts/verify_profit_pipeline.ts",
    "preflight:runtime-deps": "pnpm preflight:runtime-deps:dev",
    "preflight:runtime-deps:dev": "pnpm env:dev && node --import tsx scripts/preflight_runtime_dependencies.ts",
    "preflight:runtime-deps:prod": "ALLOW_PROD_ENV_SWITCH=true pnpm env:prod && node --import tsx scripts/preflight_runtime_dependencies.ts",
    "preflight:worker-runtime": "NODE_OPTIONS=--no-deprecation node --import tsx scripts/check_worker_runtime_dependencies.ts",
    "diag:db-fingerprint": "node scripts/check_runtime_db_fingerprint.mjs",
    "diag:env-compare": "node scripts/compare_local_and_vercel_env.mjs production",
    "diag:vercel-env-access": "node --import tsx scripts/check_vercel_env_access.ts production",
    "check:tracking-test-order": "node --import tsx scripts/check_tracking_sync_test_order.ts",
    "repo-tree:update": "node scripts/update_repo_tree.mjs",
    "repo-tree:watch": "node scripts/watch_repo_tree.mjs",
    "check:migration-ledger": "node --import tsx scripts/check_migration_ledger.ts",
    "diag:queue-namespace": "node --import tsx scripts/queue_namespace_diagnostics.ts",
    "check:inventory-risk-schedule": "node --import tsx scripts/check_inventory_risk_schedule.ts",
    "check:upstream-schedules": "node --import tsx scripts/check_upstream_schedules.ts",
    "check:worker-run-truth": "node --import tsx scripts/check_worker_run_truth.ts",
    "check:schema-drift": "node --import tsx scripts/check_schema_drift.ts",
    "ops:listing-phase1-recheck": "node --import tsx scripts/run_listing_phase1_recheck.ts",
    "enqueue:listing-optimize": "NODE_OPTIONS=--no-deprecation node --import tsx scripts/enqueue_listing_optimize.ts",
    "worker:railway-env:build": "NODE_OPTIONS=--no-deprecation node --import tsx scripts/build_railway_worker_env.ts",
    "worker:railway-env:validate": "NODE_OPTIONS=--no-deprecation node --import tsx scripts/validate_railway_worker_env.ts"
  },
  "dependencies": {
    "bullmq": "^5.70.2",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.10.0",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract",
      "sharp",
      "unrs-resolver"
    ]
  }
}
